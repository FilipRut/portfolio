---
---
<div id="chat-overlay" class="chat-overlay">
    <div id="chat-dim" class="chat-dim"></div>
</div>

<style>
    .chat-overlay {
        position: fixed;
        inset: 0;
        z-index: 99;
        pointer-events: none;
        visibility: hidden;
    }
    .chat-overlay.is-active {
        pointer-events: auto;
        visibility: visible;
    }
    .chat-dim {
        position: absolute;
        inset: 0;
        background: rgba(0, 0, 0, 0.55);
        backdrop-filter: blur(6px);
        opacity: 0;
    }
</style>
