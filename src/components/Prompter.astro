---
import PixelBuddy from './PixelBuddy.astro';
---
<div id="prompter-fixed" class="prompter-fixed">
    <!-- SVG frosted glass filter -->
    <svg style="position:absolute;width:0;height:0;">
        <defs>
            <filter id="frosted" x="-20%" y="-20%" width="140%" height="140%">
                <feTurbulence type="fractalNoise" baseFrequency="0.012" numOctaves="2" seed="2" result="noise"/>
                <feDisplacementMap in="SourceGraphic" in2="noise" scale="6" xChannelSelector="R" yChannelSelector="G"/>
            </filter>
        </defs>
    </svg>

    <div class="prompter-column">
        <div class="prompter-row">
            <div class="glass-wrapper">
                <div class="glass-container">
                    <!-- Chat messages (inline, hidden until chat mode) -->
                    <div id="chat-messages-inline" class="chat-messages-inline"></div>
                    <button id="chat-close-inline" class="chat-close-inline" aria-label="Close chat">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                            <path d="M18 6L6 18M6 6l12 12"/>
                        </svg>
                    </button>
                    <div class="prompter-textarea-wrap">
                        <textarea id="ai-prompt" class="prompter-textarea" placeholder="" aria-label="Ask me anything about my work"></textarea>
                        <div id="matrix-cursor" class="matrix-cursor"></div>

                        <!-- Custom placeholder with sliding track -->
                        <div class="placeholder-overlay">
                            <div id="placeholder-track" class="placeholder-track">
                                <span id="placeholder-text" class="placeholder-text"></span>
                                <span id="placeholder-cursor" class="placeholder-cursor"></span>
                            </div>
                        </div>

                        <!-- Response overlay (top) -->
                        <div class="glass-overlay-top">
                            <div id="ai-response-title" class="text-white font-medium leading-none" style="font-size: clamp(2rem, 1.5rem + 2vw, 4rem);"></div>
                            <p id="ai-response-text" class="font-normal leading-relaxed" style="font-size: clamp(0.9375rem, 0.85rem + 0.3vw, 1.1rem); margin-top: clamp(0.4rem, 0.3rem + 0.2vw, 0.6rem); color: rgba(255,255,255,0.7);"></p>
                        </div>

                        <!-- Loading spinner -->
                        <div id="chat-spinner" class="chat-spinner">
                            <div class="chat-spinner-dot"></div>
                            <div class="chat-spinner-dot"></div>
                            <div class="chat-spinner-dot"></div>
                            <div class="chat-spinner-dot"></div>
                            <div class="chat-spinner-dot"></div>
                            <div class="chat-spinner-dot"></div>
                            <div class="chat-spinner-dot"></div>
                            <div class="chat-spinner-dot"></div>
                        </div>

                        <!-- Send button + bubbles -->
                        <div class="glass-overlay-bottom">
                            <div class="prompt-bubbles">
                                <button class="prompt-bubble" data-prompt="Your projects?">Projects?</button>
                                <button class="prompt-bubble" data-prompt="What does your design process look like?">Process?</button>
                                <button class="prompt-bubble" data-prompt="Are you open to freelance work?">Hire?</button>
                            </div>
                            <button id="generate-btn" class="prompter-send" aria-label="Send">
                                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:block; transform: translate(-1px, 1px);">
                                    <path d="M22 2L11 13"></path>
                                    <path d="M22 2L15 22L11 13L2 9L22 2Z"></path>
                                </svg>
                            </button>
                        </div>
                    </div>
                </div>
                <PixelBuddy />
            </div>
        </div>
    </div>
</div>

<style>
    .prompter-fixed {
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        bottom: 0;
        z-index: 100;
        display: flex;
        justify-content: center;
        padding: 0 clamp(1.5rem, 1rem + 2vw, 3rem);
        pointer-events: none;
        overflow: hidden;
    }

    .prompter-fixed > .prompter-column {
        pointer-events: none;
    }

    .prompter-column .glass-container {
        pointer-events: auto;
    }

    .prompter-column {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: stretch;
        width: 100%;
        max-width: 50%;
        gap: clamp(0.75rem, 0.5rem + 0.5vw, 1.25rem);
        will-change: transform;
    }

    .prompter-row {
        display: flex;
        align-items: center;
        width: 100%;
        gap: clamp(0.5rem, 0.3rem + 0.3vw, 0.75rem);
    }

    @media (min-width: 2000px) {
        .prompter-column { max-width: 40%; }
    }

    @media (max-width: 1024px) {
        .prompter-column { max-width: 80%; }
    }

    @media (max-width: 640px) {
        .prompter-column { max-width: 95%; }
    }

    .glass-wrapper {
        position: relative;
        width: 100%;
    }

    .glass-container {
        position: relative;
        display: flex;
        flex-direction: column;
        width: 100%;
        min-height: clamp(16rem, 12rem + 8vw, 24rem);
        border-radius: clamp(0.75rem, 0.5rem + 0.5vw, 1.25rem);
        background: rgba(255, 255, 255, 0.04);
        backdrop-filter: blur(16px) saturate(150%);
        -webkit-backdrop-filter: blur(16px) saturate(150%);
        will-change: transform, min-height, border-radius;
        contain: layout style;
        border: 1px solid rgba(255, 255, 255, 0.1);
        box-shadow:
            0 8px 32px rgba(0, 0, 0, 0.25),
            inset 0 1px 0 rgba(255, 255, 255, 0.08);
        overflow: hidden;
        transition: background 0.4s ease, border-color 0.4s ease, box-shadow 0.45s ease;
        padding: clamp(0.4rem, 0.3rem + 0.2vw, 0.6rem);
    }

    .glass-container.chat-mode {
        background: rgba(255, 255, 255, 0.92);
        border-color: rgba(0, 0, 0, 0.08);
        box-shadow: 0 24px 80px rgba(0, 0, 0, 0.28);
    }

    .prompter-textarea-wrap {
        position: relative;
        flex: 1;
        min-height: clamp(14rem, 10rem + 7vw, 22rem);
        border-radius: clamp(0.5rem, 0.35rem + 0.3vw, 0.85rem);
        background: rgba(255, 255, 255, 0.04);
        /* backdrop-filter removed — parent .glass-container already provides blur */
        border: 0.75px solid rgba(255, 255, 255, 0.08);
        box-shadow:
            inset 0 2px 8px rgba(0, 0, 0, 0.35),
            inset 0 1px 2px rgba(0, 0, 0, 0.25),
            inset 0 -1px 0 rgba(255, 255, 255, 0.04);
        overflow: hidden;
    }

    .prompter-textarea {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
        font-family: 'Inter Tight', sans-serif;
        font-size: clamp(0.9375rem, 0.85rem + 0.25vw, 1.1rem);
        padding: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);
        padding-bottom: clamp(4.5rem, 3.5rem + 1.5vw, 6rem);
        background: transparent;
        border: none;
        color: rgba(255, 255, 255, 0.9);
        outline: none;
        resize: none;
        overflow: hidden;
        line-height: 1.6;
        caret-color: transparent;
        scrollbar-width: none;
        text-overflow: ellipsis;
    }

    .matrix-cursor {
        position: absolute;
        width: 0.55em;
        background: rgba(0, 230, 64, 0.75);
        box-shadow: 0 0 6px rgba(0, 230, 64, 0.4), 0 0 14px rgba(0, 230, 64, 0.15);
        pointer-events: none;
        z-index: 5;
        display: none;
        border-radius: 1px;
        animation: matrix-blink 0.9s step-start infinite;
    }

    .placeholder-overlay {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 100%;
        overflow: hidden;
        pointer-events: none;
        z-index: 1;
    }

    .placeholder-track {
        display: inline-flex;
        align-items: center;
        white-space: nowrap;
        height: auto;
        transition: transform 0.12s ease-out;
    }

    .placeholder-text {
        font-family: 'Inter Tight', sans-serif;
        color: rgba(255, 255, 255, 0.35);
        line-height: 1.6;
    }

    .placeholder-cursor {
        display: none;
        width: 0.55em;
        height: 0.85em;
        margin-left: 0.3em;
        background: rgba(255, 255, 255, 0.3);
        border-radius: 1px;
        flex-shrink: 0;
        animation: matrix-blink 0.9s step-start infinite;
    }

    @keyframes matrix-blink {
        0%, 49% { opacity: 1; }
        50%, 100% { opacity: 0; }
    }

    /* Light mode overrides */
    .prompter-fixed.on-light .prompter-textarea { color: rgba(0, 0, 0, 0.85); }
    .prompter-fixed.on-light .prompter-textarea::placeholder { color: rgba(0, 0, 0, 0.45); }
    .prompter-fixed.on-light .matrix-cursor {
        background: rgba(0, 180, 50, 0.7);
        box-shadow: 0 0 6px rgba(0, 180, 50, 0.3), 0 0 14px rgba(0, 180, 50, 0.1);
    }
    .prompter-fixed.on-light .placeholder-text { color: rgba(0, 0, 0, 0.35); }
    .prompter-fixed.on-light .placeholder-cursor { background: rgba(0, 0, 0, 0.25); }
    .prompter-fixed.on-light .glass-container {
        border-color: rgba(0, 0, 0, 0.08);
        box-shadow: 0 8px 32px rgba(0, 0, 0, 0.1), inset 0 1px 0 rgba(255, 255, 255, 0.5);
    }
    .prompter-fixed.on-light .prompter-textarea-wrap {
        border-color: rgba(0, 0, 0, 0.06);
        box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.08), inset 0 1px 2px rgba(0, 0, 0, 0.06);
    }
    .prompter-fixed.on-light #ai-response-title { color: rgba(0, 0, 0, 0.9); }
    .prompter-fixed.on-light #ai-response-text { color: rgba(0, 0, 0, 0.55); }

    .glass-overlay-top {
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        padding: clamp(1.25rem, 1rem + 0.5vw, 2rem);
        pointer-events: none;
        z-index: 2;
    }

    .glass-overlay-bottom {
        position: absolute;
        bottom: 0;
        left: 0;
        right: 0;
        display: flex;
        align-items: center; /* Centered instead of flex-end */
        justify-content: flex-end;
        gap: clamp(0.6rem, 0.5rem + 0.5vw, 1rem); /* Increased gap */
        padding: clamp(0.75rem, 0.5rem + 0.4vw, 1.25rem);
        z-index: 2;
    }

    .prompt-bubbles {
        display: flex;
        flex-wrap: wrap;
        justify-content: flex-end;
        align-items: center; /* Centered instead of flex-end */
        gap: 0.5rem;
    }

    .prompt-bubble {
        font-family: 'Inter Tight', sans-serif;
        font-size: clamp(0.75rem, 0.65rem + 0.25vw, 0.95rem);
        padding: clamp(0.35rem, 0.3rem + 0.15vw, 0.55rem) clamp(0.75rem, 0.6rem + 0.4vw, 1.1rem);
        height: auto;
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 999px;
        background: rgba(255, 255, 255, 0.08);
        color: rgba(255, 255, 255, 0.7);
        cursor: pointer;
        transition: background 0.2s ease, color 0.2s ease;
        border: 0.75px solid rgba(255, 255, 255, 0.08);
    }

    .prompt-bubble:hover {
        background: rgba(255, 255, 255, 0.14);
        color: #fff;
    }

    .prompter-fixed.on-light .prompt-bubble {
        background: rgba(0, 0, 0, 0.05);
        color: rgba(0, 0, 0, 0.6);
        border-color: rgba(0, 0, 0, 0.06);
    }

    .prompter-fixed.on-light .prompt-bubble:hover {
        background: rgba(0, 0, 0, 0.1);
        color: rgba(0, 0, 0, 0.85);
    }

    .prompter-send {
        width: clamp(2.5rem, 2.25rem + 0.5vw, 3rem);
        height: clamp(2.5rem, 2.25rem + 0.5vw, 3rem);
        min-width: 2rem;   /* GSAP overrides size; WCAG target met by clamp minimum */
        min-height: 2rem;
        flex-shrink: 0;
        border-radius: 50%;
        background: rgba(229, 62, 62, 0.85);
        color: #fff;
        cursor: pointer;
        display: grid;
        place-items: center;
        transition: background 0.25s ease;
    }

    /* ── Chat messages inline ── */
    .chat-messages-inline {
        display: none;
        flex: 1;
        overflow-y: auto;
        padding: 2.5rem 1rem 0.5rem;
        flex-direction: column;
        gap: 0.5rem;
        min-height: 0;
        /* Custom scrollbar — thumb matches send button color */
        scrollbar-width: thin;
        scrollbar-color: rgba(229, 62, 62, 0.7) transparent;
    }

    .chat-messages-inline::-webkit-scrollbar {
        width: 6px;
    }

    .chat-messages-inline::-webkit-scrollbar-track {
        background: transparent;
    }

    .chat-messages-inline::-webkit-scrollbar-thumb {
        background: rgba(229, 62, 62, 0.7);
        border-radius: 3px;
    }

    .chat-messages-inline::-webkit-scrollbar-thumb:hover {
        background: rgba(229, 62, 62, 0.9);
    }

    /* Push messages to bottom when content is short */
    .chat-messages-inline::before {
        content: '';
        flex: 1;
    }

    .chat-close-inline {
        display: none;
        position: absolute;
        top: 0.6rem;
        right: 0.6rem;
        width: clamp(1.5rem, 1.25rem + 0.5vw, 1.75rem);
        height: clamp(1.5rem, 1.25rem + 0.5vw, 1.75rem);
        border-radius: 50%;
        background: rgba(0, 0, 0, 0.06);
        color: rgba(0, 0, 0, 0.4);
        place-items: center;
        cursor: pointer;
        z-index: 5;
        border: none;
        transition: background 0.2s ease;
    }

    .chat-close-inline:hover {
        background: rgba(0, 0, 0, 0.12);
    }

    .chat-bubble {
        max-width: 80%;
        padding: 0.5rem 0.85rem;
        border-radius: 1rem;
        font-family: 'Inter Tight', sans-serif;
        font-size: 0.875rem;
        line-height: 1.5;
        word-wrap: break-word;
    }

    .chat-bubble--user {
        align-self: flex-end;
        background: rgba(229, 62, 62, 0.9);
        color: #fff;
        border-bottom-right-radius: 0.3rem;
    }

    .chat-bubble--bot {
        align-self: flex-start;
        background: rgba(0, 0, 0, 0.06);
        color: rgba(0, 0, 0, 0.85);
        border-bottom-left-radius: 0.3rem;
    }

    /* Chat mode textarea-wrap acts as input bar */
    .glass-container.chat-mode .prompter-textarea-wrap {
        border-color: rgba(0, 0, 0, 0.06);
        box-shadow: inset 0 2px 8px rgba(0, 0, 0, 0.08), inset 0 1px 2px rgba(0, 0, 0, 0.06);
    }

    .glass-container.chat-mode .prompter-textarea {
        color: rgba(0, 0, 0, 0.85);
    }

    .glass-container.chat-mode .prompter-textarea::placeholder {
        color: rgba(0, 0, 0, 0.4);
    }

    .glass-container.chat-mode .prompt-bubble {
        background: rgba(0, 0, 0, 0.05);
        color: rgba(0, 0, 0, 0.6);
        border-color: rgba(0, 0, 0, 0.06);
    }

    .glass-container.chat-mode .prompt-bubble:hover {
        background: rgba(0, 0, 0, 0.1);
        color: rgba(0, 0, 0, 0.85);
    }

    @media (max-width: 767px) {
        .prompter-fixed { align-items: flex-end; padding-bottom: 1rem; }
        .prompter-textarea { color: rgba(0, 0, 0, 0.85); }
        .glass-container { background: rgba(255, 255, 255, 0.9); }
    }
</style>

