---
import '../styles/global.css';
---

<html lang="pl">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Filip Rut – Lead UX/UI Designer</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
	</head>
	<body class="m-0 p-0 font-['Inter_Tight',sans-serif] bg-white">

		<!-- Vignette spotlight — pojawia się gdy kompozer jest na środku -->
		<div id="scene-vignette"></div>

		<!-- ═══ SCROLL WRAPPER: Hero stays frozen while prompter animates ═══ -->
		<div id="scroll-wrapper" class="scroll-wrapper">
			<section id="hero" class="hero-sticky" style="background-color: #E53E3E;">
				<!-- Gradient overlay -->
				<div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 50% 0%, rgba(220,50,50,0.4) 0%, transparent 60%), radial-gradient(ellipse at 80% 100%, rgba(100,0,0,0.3) 0%, transparent 50%);"></div>

				<!-- Frosted ribbed glass effect -->
				<div id="hero-glass" class="hero-glass">
					<div class="hero-glass-gradient"></div>
					<div class="hero-glass-frost"></div>
				</div>

				<!-- 6 vertical lines → 5 columns -->
				<div class="absolute inset-0 px-4 md:px-16 flex justify-between pointer-events-none">
					<div class="hero-line w-[2px] h-full" style="background-color: rgba(23,23,23,0.25);"></div>
					<div class="hero-line w-[2px] h-full hidden md:block" style="background-color: rgba(23,23,23,0.25);"></div>
					<div class="hero-line w-[2px] h-full hidden sm:block" style="background-color: rgba(23,23,23,0.25);"></div>
					<div class="hero-line w-[2px] h-full hidden md:block" style="background-color: rgba(23,23,23,0.25);"></div>
					<div class="hero-line w-[2px] h-full hidden md:block" style="background-color: rgba(23,23,23,0.25);"></div>
					<div class="hero-line w-[2px] h-full" style="background-color: rgba(23,23,23,0.25);"></div>
				</div>

				<!-- Top bar -->
				<div class="relative z-10 w-full px-4 md:px-16 pt-6 md:pt-8 pb-4 grid grid-cols-2 md:grid-cols-5 self-start" style="align-items: center;">
					<div class="flex justify-center"><span class="hero-label hero-tag tracking-tight" style="font-size: clamp(0.75rem, 0.6rem + 0.4vw, 0.9rem);">Filip Rut</span></div>
					<div class="hidden md:flex justify-center"><span class="hero-label hero-tag tracking-tight" style="font-size: clamp(0.75rem, 0.6rem + 0.4vw, 0.9rem);">Lead UX/UI Designer</span></div>
					<div class="hidden md:flex justify-center"><span class="hero-label hero-tag tracking-tight" style="font-size: clamp(0.75rem, 0.6rem + 0.4vw, 0.9rem);">10 yrs exp</span></div>
					<div class="hidden md:flex justify-center">
						<span class="hero-label hero-tag tracking-tight" style="font-size: clamp(0.75rem, 0.6rem + 0.4vw, 0.9rem);">
							<span style="opacity:0.55;">Warsaw time</span>
							<span style="opacity:0.35;">—</span>
							<span id="hero-clock"></span>
						</span>
					</div>
					<div class="flex justify-center">
						<a href="mailto:filiprut@example.com" class="hero-tag hero-contact-btn tracking-tight" style="font-size: clamp(0.75rem, 0.6rem + 0.4vw, 0.9rem);">Contact me</a>
					</div>
				</div>

				<!-- Pause button -->
				<button id="hero-pause-btn" class="hero-pause-btn" aria-label="Pause background animation">
					<svg id="hero-pause-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
						<rect x="5" y="4" width="4" height="16" rx="1"/>
						<rect x="15" y="4" width="4" height="16" rx="1"/>
					</svg>
					<svg id="hero-play-icon" width="16" height="16" viewBox="0 0 24 24" fill="currentColor" style="display:none;">
						<polygon points="6,4 20,12 6,20"/>
					</svg>
				</button>

			<!-- Big RUT text -->
				<div class="absolute bottom-0 left-0 right-0 flex justify-center pointer-events-none select-none" style="overflow: hidden; line-height: 0;">
					<span class="hero-letter font-medium" style="color: #171717;">R</span>
					<span class="hero-letter font-medium" style="color: #171717; position: relative; z-index: 3;">U</span>
					<span class="hero-letter font-medium" style="color: #171717;">T</span>
				</div>
			</section>
		</div>

		<!-- ═══ AI PROMPTER (fixed overlay, persists across entire page) ═══ -->
		<div id="prompter-fixed" class="prompter-fixed">
			<!-- SVG frosted glass filter -->
			<svg style="position:absolute;width:0;height:0;">
				<defs>
					<filter id="frosted" x="-20%" y="-20%" width="140%" height="140%">
						<feTurbulence type="fractalNoise" baseFrequency="0.012" numOctaves="2" seed="2" result="noise"/>
						<feDisplacementMap in="SourceGraphic" in2="noise" scale="6" xChannelSelector="R" yChannelSelector="G"/>
					</filter>
				</defs>
			</svg>

			<div class="prompter-column">
				<div class="prompter-row">
					<!-- Dropdown toggle (hidden initially, appears on collapse) -->
					<button id="dropdown-btn" class="prompter-dropdown" aria-label="Show suggestions">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:block;">
							<path d="M6 9l6 6 6-6"></path>
						</svg>
					</button>

					<div class="glass-wrapper">
						<div class="glass-container">
							<!-- Inner glass layer (inset/concave) -->
							<div class="prompter-textarea-wrap">
								<textarea id="ai-prompt" class="prompter-textarea" placeholder="Ask AI about me..."></textarea>
								<div id="matrix-cursor" class="matrix-cursor"></div>

								<!-- Response overlay (top) -->
								<div class="glass-overlay-top">
									<div id="ai-response-title" class="text-white font-medium leading-none" style="font-size: clamp(2rem, 1.5rem + 2vw, 4rem);"></div>
									<p id="ai-response-text" class="font-normal leading-relaxed" style="font-size: clamp(0.9375rem, 0.85rem + 0.3vw, 1.1rem); margin-top: clamp(0.4rem, 0.3rem + 0.2vw, 0.6rem); color: rgba(255,255,255,0.7);"></p>
								</div>

								<!-- Loading spinner -->
								<div id="chat-spinner" class="chat-spinner">
									<div class="chat-spinner-dot"></div>
									<div class="chat-spinner-dot"></div>
									<div class="chat-spinner-dot"></div>
									<div class="chat-spinner-dot"></div>
									<div class="chat-spinner-dot"></div>
									<div class="chat-spinner-dot"></div>
									<div class="chat-spinner-dot"></div>
									<div class="chat-spinner-dot"></div>
								</div>

								<!-- Send button -->
								<div class="glass-overlay-bottom">
									<div class="flex-1"></div>
									<button id="generate-btn" class="prompter-send" aria-label="Send">
										<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:block;">
											<path d="M22 2L11 13"></path>
											<path d="M22 2L15 22L11 13L2 9L22 2Z"></path>
										</svg>
									</button>
								</div>
							</div>
						</div>

						<!-- Pixel buddy -->
						<div id="pixel-buddy-wrap" class="pixel-buddy-wrap">
							<div class="pixel-buddy-inner">
								<canvas id="pixel-buddy" width="108" height="72" style="image-rendering: pixelated; display: block;"></canvas>
							</div>
						</div>
					</div>
				</div>

				<!-- Suggestion bubbles (outside glass container) -->
				<div class="prompt-bubbles">
					<button class="prompt-bubble" data-prompt="What projects have you worked on?">What projects have you worked on?</button>
					<button class="prompt-bubble" data-prompt="What does your design process look like?">What does your design process look like?</button>
					<button class="prompt-bubble" data-prompt="What tools do you use?">What tools do you use?</button>
				</div>
			</div>
		</div>

		<!-- ═══ CHAT OVERLAY ═══ -->
		<div id="chat-overlay" class="chat-overlay">
			<div id="chat-dim" class="chat-dim"></div>
			<div id="chat-modal" class="chat-modal">
				<button id="chat-close" class="chat-close" aria-label="Close chat">
					<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
						<path d="M18 6L6 18M6 6l12 12"/>
					</svg>
				</button>
				<div id="chat-messages" class="chat-messages"></div>
				<div class="chat-input-area">
					<div class="chat-input-wrap">
						<input id="chat-input" type="text" class="chat-input" placeholder="Type a message..." />
						<button id="chat-send" class="chat-send-btn" aria-label="Send">
							<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
								<path d="M22 2L11 13"></path>
								<path d="M22 2L15 22L11 13L2 9L22 2Z"></path>
							</svg>
						</button>
					</div>
				</div>
			</div>
		</div>

		<!-- ═══ INTRO ═══ -->
		<section id="intro" class="w-full bg-white">
			<div class="flex flex-col lg:flex-row items-start lg:items-center" style="padding: clamp(1rem, 0.5rem + 1vw, 1.5rem) 0; gap: clamp(1.5rem, 1rem + 2vw, 3rem);">
				<!-- Photo + Heading group -->
				<div class="flex items-center shrink-0" style="gap: clamp(0.75rem, 0.5rem + 1vw, 1.5rem);">
					<img
						src="https://placehold.co/111x160/e5e5e5/737373?text=Photo"
						alt="Filip Rut"
						class="intro-el object-cover rounded"
						style="width: clamp(4rem, 3rem + 3vw, 7rem); height: clamp(5.5rem, 4rem + 4vw, 10rem);"
					/>
					<h2 class="intro-el text-stone-950 font-normal leading-tight" style="font-size: clamp(1.5rem, 1rem + 2.5vw, 3.5rem); max-width: 32rem;">
						Leading above the corporate chaos
					</h2>
				</div>

				<!-- Image + Description group -->
				<div class="flex-1 flex items-center" style="gap: clamp(0.75rem, 0.5rem + 1vw, 1.5rem); padding-left: clamp(0rem, 2vw, 5rem);">
					<img
						src="https://placehold.co/247x159/e5e5e5/737373?text=Keychains"
						alt="Design artifacts"
						class="intro-el object-cover shrink-0"
						style="width: clamp(6rem, 4rem + 6vw, 15rem); height: clamp(4rem, 3rem + 4vw, 10rem);"
					/>
					<p class="intro-el text-orange-950 font-normal leading-snug" style="font-size: clamp(0.875rem, 0.7rem + 0.8vw, 1.35rem);">
						An experienced Lead UX/UI designer and Webflow developer, delivering high-quality designs and websites.
					</p>
				</div>
			</div>
		</section>

		<style is:global>
			/* Scroll wrapper — tall container, hero stays sticky inside */
			.scroll-wrapper {
				position: relative;
				height: 200vh; /* 100vh slide + 100vh collapse */
			}

			/* Hero sticky inside wrapper */
			.hero-sticky {
				position: sticky;
				top: 0;
				height: 100vh;
				z-index: 1;
				display: flex;
				flex-direction: column;
				overflow: hidden;
			}

			/* Frosted ribbed glass effect */
			.hero-glass {
				position: absolute;
				inset: 0;
				overflow: hidden;
				pointer-events: none;
				z-index: 0;
				mask-image: linear-gradient(
					to right,
					rgba(0,0,0,0) 3%,
					rgba(0,0,0,1) 15%,
					rgba(0,0,0,1) 85%,
					rgba(0,0,0,0) 97%
				);
			}

			.hero-glass-gradient {
				position: absolute;
				inset: -20%;
				background: radial-gradient(
					ellipse at 50% 50%,
					rgba(210, 50, 50, 0.15) 0%,
					transparent 70%
				);
				mix-blend-mode: hard-light;
			}

			.hero-glass-frost {
				position: absolute;
				inset: 0;
				width: 200%;
				background-image: repeating-linear-gradient(
					to right,
					rgba(255, 255, 255, 0.04) 0%,
					rgba(0, 0, 0, 0.39) 49%,
					rgba(255, 255, 255, 0.27) 100%
				);
				background-size: 40px;
				mix-blend-mode: color-dodge;
				will-change: transform;
				transform: translateZ(0);
			}

			/* Ensure hero labels visible without JS (GSAP fallback) */
			.hero-label,
			.hero-contact-btn {
				opacity: 1;
			}

			/* Intro section */
			#intro {
				min-height: 100vh;
				padding: clamp(5rem, 4rem + 2vw, 7rem) clamp(1.5rem, 1rem + 3vw, 4rem) clamp(2rem, 1.5rem + 2vw, 4rem);
			}

			/* Fixed prompter overlay */
			.prompter-fixed {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				bottom: 0;
				z-index: 100;
				display: flex;
				justify-content: center;
				padding: 0 clamp(1.5rem, 1rem + 2vw, 3rem);
				pointer-events: none;
				overflow: hidden;
			}

			.prompter-fixed > .prompter-column {
				pointer-events: auto;
			}

			.hero-text {
				font-family: 'Inter Tight', sans-serif;
				font-size: clamp(180px, min(61vh, 38vw), 1000px);
				line-height: 0.82;
				letter-spacing: 0.02em;
				margin-bottom: -0.04em;
			}

			.hero-letter {
				font-family: 'Inter Tight', sans-serif;
				font-size: clamp(180px, min(61vh, 38vw), 1000px);
				line-height: 0.82;
				letter-spacing: 0.02em;
				display: inline-block;
				vertical-align: bottom;
				margin-bottom: -0.08em;
			}

			#scene-vignette {
				position: fixed;
				inset: 0;
				pointer-events: none;
				z-index: 4;
				background: radial-gradient(ellipse 60% 70% at 50% 52%, transparent 0%, rgba(0,0,0,0.18) 45%, rgba(0,0,0,0.52) 100%);
				opacity: 0;
				will-change: opacity;
			}

			.hero-tag {
				display: inline-flex;
				align-items: center;
				gap: 0.4em;
				padding: clamp(0.3rem, 0.25rem + 0.15vw, 0.45rem) clamp(0.7rem, 0.5rem + 0.35vw, 1rem);
				border-radius: 6px;
				border: 0.75px solid transparent;
				background: rgba(255, 255, 255, 0.08);
				color: rgba(255, 255, 255, 0.9);
				white-space: nowrap;
				font-weight: 400;
				font-size: clamp(0.75rem, 0.6rem + 0.4vw, 0.9rem);
				line-height: 1;
				letter-spacing: 0.03em;
				box-shadow:
					0 0 0 0.75px rgba(255, 255, 255, 0.08),
					0 4px 12px rgba(0, 0, 0, 0.1);
				backdrop-filter: blur(12px) saturate(120%);
				-webkit-backdrop-filter: blur(12px) saturate(120%);
			}

			.hero-pause-btn {
				position: absolute;
				bottom: clamp(1rem, 1.5vw, 2rem);
				right: clamp(1.5rem, 4vw, 4rem);
				margin-right: 1rem;
				z-index: 10;
				width: 48px;
				height: 48px;
				border-radius: 50%;
				border: 0.75px solid transparent;
				background: rgba(255, 255, 255, 0.08);
				color: #fff;
				cursor: pointer;
				display: grid;
				place-items: center;
				line-height: 0;
				transition: all 0.25s ease;
				box-shadow:
					0 0 0 0.75px rgba(255, 255, 255, 0.08),
					0 8px 20px rgba(0, 0, 0, 0.12);
				backdrop-filter: blur(12px) saturate(120%);
				-webkit-backdrop-filter: blur(12px) saturate(120%);
			}

			.hero-pause-btn:hover {
				background: rgba(255, 255, 255, 0.14);
				transform: translateY(-1px) scale(1.08);
				box-shadow:
					0 0 0 0.75px rgba(255, 255, 255, 0.15),
					0 10px 24px rgba(0, 0, 0, 0.18);
			}

			.hero-contact-btn {
				border-radius: 999px;
				text-decoration: none;
				cursor: pointer;
				align-self: center;
				transition: background 0.25s ease, box-shadow 0.25s ease, transform 0.25s ease;
			}

			.hero-contact-btn:hover {
				background: rgba(255, 255, 255, 0.14);
				box-shadow:
					0 0 0 0.75px rgba(255, 255, 255, 0.15),
					0 10px 24px rgba(0, 0, 0, 0.18);
				transform: translateY(-1px);
			}

			.prompter-column {
				position: relative;
				display: flex;
				flex-direction: column;
				align-items: stretch;
				width: 100%;
				max-width: 50%;
				gap: clamp(0.75rem, 0.5rem + 0.5vw, 1.25rem);
				will-change: transform;
			}

			.prompter-row {
				display: flex;
				align-items: center;
				width: 100%;
				gap: clamp(0.5rem, 0.3rem + 0.3vw, 0.75rem);
			}

			.prompter-dropdown {
				position: absolute;
				left: -56px;
				top: 0;
				width: 48px;
				height: 48px;
				min-width: 48px;
				border-radius: 50%;
				border: 0.75px solid transparent;
				background: rgba(255, 255, 255, 0.08);
				color: #fff;
				cursor: pointer;
				display: grid;
				place-items: center;
				padding: 0;
				line-height: 0;
				transition: none;
				box-shadow:
					0 0 0 0.75px rgba(255, 255, 255, 0.08),
					0 8px 20px rgba(0, 0, 0, 0.12);
				backdrop-filter: blur(12px) saturate(120%);
				-webkit-backdrop-filter: blur(12px) saturate(120%);
				opacity: 0;
				pointer-events: none;
			}

			.prompter-dropdown.is-visible {
				opacity: 1;
				pointer-events: auto;
				transform: translateX(0);
			}

			.prompter-dropdown:hover {
				background: rgba(255, 255, 255, 0.14);
				box-shadow:
					0 0 0 0.75px rgba(255, 255, 255, 0.15),
					0 10px 24px rgba(0, 0, 0, 0.18);
			}

			.prompter-dropdown.is-open svg {
				transform: rotate(180deg);
			}

			.prompter-dropdown svg {
				transition: transform 0.3s ease;
			}

			@media (min-width: 2000px) {
				.prompter-column { max-width: 40%; }
			}

			@media (max-width: 1024px) {
				.prompter-column { max-width: 80%; }
			}

			@media (max-width: 640px) {
				.prompter-column { max-width: 95%; }
			}

			/* Glass container — outer layer */
			.glass-container {
				position: relative;
				width: 100%;
				min-height: clamp(16rem, 12rem + 8vw, 24rem);
				border-radius: clamp(0.75rem, 0.5rem + 0.5vw, 1.25rem);
				background: rgba(255, 255, 255, 0.04);
				backdrop-filter: blur(24px) saturate(150%);
				-webkit-backdrop-filter: blur(24px) saturate(150%);
				will-change: transform, min-height, border-radius;
				border: 1px solid rgba(255, 255, 255, 0.1);
				box-shadow:
					0 8px 32px rgba(0, 0, 0, 0.25),
					inset 0 1px 0 rgba(255, 255, 255, 0.08);
				overflow: hidden;
				padding: clamp(0.4rem, 0.3rem + 0.2vw, 0.6rem);
			}

			/* Textarea wrapper — inner glass layer, denser, inset look */
			.prompter-textarea-wrap {
				position: relative;
				flex: 1;
				min-height: clamp(14rem, 10rem + 7vw, 22rem);
				border-radius: clamp(0.5rem, 0.35rem + 0.3vw, 0.85rem);
				background: rgba(255, 255, 255, 0.04);
				backdrop-filter: blur(16px) saturate(130%);
				-webkit-backdrop-filter: blur(16px) saturate(130%);
				border: 0.75px solid rgba(255, 255, 255, 0.08);
				box-shadow:
					inset 0 2px 8px rgba(0, 0, 0, 0.35),
					inset 0 1px 2px rgba(0, 0, 0, 0.25),
					inset 0 -1px 0 rgba(255, 255, 255, 0.04);
				overflow: hidden;
			}

			/* Textarea — fills inner glass, fully transparent */
			.prompter-textarea {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				font-family: 'Inter Tight', sans-serif;
				font-size: clamp(0.9375rem, 0.85rem + 0.25vw, 1.1rem);
				padding: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);
				padding-bottom: clamp(3.5rem, 3rem + 1vw, 5rem);
				background: transparent;
				border: none;
				color: rgba(255, 255, 255, 0.9);
				outline: none;
				resize: none;
				overflow: hidden;
				line-height: 1.6;
				caret-color: transparent;
				scrollbar-width: none;
			}

			@keyframes matrix-blink {
				0%, 49% { opacity: 1; }
				50%, 100% { opacity: 0; }
			}

			.matrix-cursor {
				position: absolute;
				width: 2px;
				background: rgba(255, 255, 255, 0.55);
				pointer-events: none;
				z-index: 5;
				display: none;
				animation: matrix-blink 0.9s step-start infinite;
			}

			.prompter-textarea::-webkit-scrollbar {
				display: none;
			}

			.prompter-textarea::placeholder {
				color: rgba(255, 255, 255, 0.55);
				letter-spacing: 0.01em;
				transition: color 0.15s;
			}

			.prompter-textarea:focus::placeholder {
				color: rgba(255, 255, 255, 0.35);
			}


			/* ── Light mode overrides (when over white/light bg) ── */
			.prompter-fixed.on-light .prompter-textarea {
