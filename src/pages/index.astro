---
import BaseLayout from '../layouts/BaseLayout.astro';
import Hero from '../components/Hero.astro';
import Prompter from '../components/Prompter.astro';
import ChatOverlay from '../components/ChatOverlay.astro';
import Intro from '../components/Intro.astro';
import Process from '../components/Process.astro';
import AboutMe from '../components/AboutMe.astro';
import { getCollection } from 'astro:content';

const projects = (await getCollection('projects'))
	.filter(p => !p.data.draft)
	.sort((a, b) => a.data.order - b.data.order)
	.map(p => ({
		id: p.id,
		title: p.data.title,
		client: p.data.client ?? '',
		company: p.data.company ?? '',
		year: p.data.year,
		heroImage: p.data.heroImage ?? p.data.cover,
		cover: p.data.cover,
		description: p.data.description,
		tags: p.data.tags ?? [],
	}));
---

<BaseLayout>
	<!-- Project data for hero gallery cards -->
	<script is:inline define:vars={{ projects }}>
		window.__heroProjects = projects;
	</script>

	<!-- Global Three.js Container for transitions -->
	<div id="global-three-container" role="img" aria-label="Interactive 3D keychain animation"></div>

	<!-- Fixed logo — appears after hero, letters draw on/off via stroke masks -->
	<a id="site-logo" href="/" class="site-logo" aria-label="RUT — back to top">
		<svg viewBox="0 0 207 100" xmlns="http://www.w3.org/2000/svg">
			<defs>
				<!-- R mask: stem bottom→top, bowl clockwise, leg diagonal -->
				<mask id="m-r">
					<path class="draw-r1" d="M 11.35 82 V 9" stroke="white" stroke-width="18" stroke-linecap="round" fill="none"/>
					<path class="draw-r2" d="M 14 14 L 38 14 Q 51.5 14 51.5 32 Q 51.5 50 38 50 L 12 50" stroke="white" stroke-width="18" stroke-linecap="round" fill="none"/>
					<path class="draw-r3" d="M 35.7 49 L 53.5 82" stroke="white" stroke-width="20" stroke-linecap="round" fill="none"/>
				</mask>
				<!-- U mask: top-left → down → arc → up to top-right -->
				<mask id="m-u">
					<path class="draw-u" d="M 79.65 9.25 V 57 Q 79.65 78 103 78 Q 126.5 78 126.5 57 V 9.25" stroke="white" stroke-width="18" stroke-linecap="round" fill="none"/>
				</mask>
				<!-- T mask: horizontal bar left→right, then vertical top→bottom -->
				<mask id="m-t">
					<path class="draw-t1" d="M 148 14 H 205" stroke="white" stroke-width="16" stroke-linecap="round" fill="none"/>
					<path class="draw-t2" d="M 176.3 14 V 82" stroke="white" stroke-width="18" stroke-linecap="round" fill="none"/>
				</mask>
			</defs>
			<!-- Filled letter paths from Inter Tight 500, revealed by animated masks -->
			<path class="logo-letter" mask="url(#m-r)" d="M16.85 82L5.86 82L5.86 9.25L31.84 9.25Q40.28 9.25 45.85 12.15Q51.42 15.06 54.20 20.21Q56.98 25.36 56.98 32.10L56.98 32.10Q56.98 38.74 54.20 43.82Q51.42 48.89 45.83 51.68Q40.23 54.46 31.74 54.46L31.74 54.46L12.16 54.46L12.16 45.09L30.71 45.09Q36.13 45.09 39.48 43.52Q42.82 41.96 44.36 39.08Q45.90 36.20 45.90 32.10L45.90 32.10Q45.90 27.95 44.34 24.94Q42.77 21.94 39.43 20.31Q36.08 18.67 30.66 18.67L30.66 18.67L16.85 18.67L16.85 82ZM59.77 82L47.27 82L29.64 49.14L41.80 49.14L59.77 82Z"/>
			<path class="logo-letter" mask="url(#m-u)" d="M120.99 56.22L120.99 9.25L131.97 9.25L131.97 57.10Q131.97 64.71 128.39 70.60Q124.80 76.48 118.30 79.83Q111.81 83.17 103.07 83.17L103.07 83.17Q94.38 83.17 87.86 79.83Q81.34 76.48 77.75 70.60Q74.16 64.71 74.16 57.10L74.16 57.10L74.16 9.25L85.15 9.25L85.15 56.22Q85.15 61.15 87.32 64.98Q89.49 68.82 93.52 71.01Q97.55 73.21 103.07 73.21L103.07 73.21Q108.63 73.21 112.64 71.01Q116.64 68.82 118.82 64.98Q120.99 61.15 120.99 56.22L120.99 56.22Z"/>
			<path class="logo-letter" mask="url(#m-t)" d="M170.83 18.67L148.08 18.67L148.08 9.25L204.43 9.25L204.43 18.67L181.77 18.67L181.77 82L170.83 82L170.83 18.67Z"/>
		</svg>
	</a>

	<!-- Vignette spotlight — pojawia się gdy kompozer jest na środku -->
	<div id="scene-vignette"></div>

	<Hero />
	<Prompter />
	<ChatOverlay />
	<Intro projects={projects} />
	<AboutMe />
<Process />

	<style is:global>
		#global-three-container {
			position: fixed;
			inset: 0;
			pointer-events: none;
			z-index: 20; /* High enough to be above backgrounds */
		}
		#global-three-container canvas {
			width: 100%;
			height: 100%;
		}
		/* ── Fixed RUT logo ── */
		.site-logo {
			position: fixed;
			top: clamp(1.25rem, 1rem + 0.5vw, 2rem);
			left: clamp(1rem, 0.5rem + 1vw, 4rem);
			z-index: 50;
			width: clamp(3.2rem, 2.8rem + 1vw, 4.5rem);
			text-decoration: none;
			pointer-events: none;
		}
		.site-logo.is-active {
			pointer-events: auto;
		}
		.site-logo svg {
			display: block;
			width: 100%;
			height: auto;
			overflow: visible;
			opacity: 0;
		}
		.site-logo.is-active svg {
			opacity: 1;
		}
		.logo-letter {
			fill: #171717;
		}
		.site-logo.is-dark .logo-letter {
			fill: #fff;
			transition: fill 0.4s ease;
		}
		/* Mask draw paths — hidden by default via strokeDashoffset set in JS */
		[class^="draw-"] {
			vector-effect: non-scaling-stroke;
		}

		#scene-vignette {
			position: fixed;
			inset: 0;
			pointer-events: none;
			z-index: 4;
			background: radial-gradient(ellipse 60% 70% at 50% 52%, transparent 0%, rgba(0,0,0,0.18) 45%, rgba(0,0,0,0.52) 100%);
			opacity: 0;
			will-change: opacity;
			contain: strict;
		}

		/* Common styles for chat bubbles (dynamicly added) */
		.chat-bubble {
			max-width: 78%;
			padding: 0.6rem 0.9rem;
			border-radius: 1.1rem;
			font-family: 'Inter Tight', sans-serif;
			font-size: 0.875rem;
			line-height: 1.5;
			animation: bubbleIn 0.35s ease-out both;
		}
		@keyframes bubbleIn {
			from { opacity: 0; transform: translateY(10px) scale(0.96); }
			to { opacity: 1; transform: translateY(0) scale(1); }
		}
		.chat-bubble--user {
			align-self: flex-end;
			background: linear-gradient(135deg, #ebebf0 0%, #dcdce6 100%);
			border: 1px solid rgba(255, 255, 255, 0.55);
			box-shadow:
				0 2px 12px rgba(0, 0, 0, 0.06),
				inset 0 1px 0 rgba(255, 255, 255, 0.65),
				inset 0 -0.5px 0 rgba(0, 0, 0, 0.03);
			color: rgba(0, 0, 0, 0.82);
			border-bottom-right-radius: 0.35rem;
		}
		.chat-bubble--bot {
			align-self: flex-start;
			background: linear-gradient(135deg, #e53e3e 0%, #c82d2d 100%);
			border: 1px solid rgba(255, 255, 255, 0.18);
			box-shadow:
				0 2px 12px rgba(229, 62, 62, 0.22),
				inset 0 1px 0 rgba(255, 255, 255, 0.18),
				inset 0 -0.5px 0 rgba(0, 0, 0, 0.08);
			color: rgba(255, 255, 255, 0.95);
			border-bottom-left-radius: 0.35rem;
		}

		.chat-spinner {
			position: absolute;
			left: 50%;
			top: 50%;
			width: clamp(2rem, 1.75rem + 0.5vw, 2.25rem);
			height: clamp(2rem, 1.75rem + 0.5vw, 2.25rem);
			margin-left: clamp(-1.125rem, -0.875rem - 0.25vw, -1rem);
			margin-top: clamp(-1.125rem, -0.875rem - 0.25vw, -1rem);
			pointer-events: none;
			opacity: 0;
			z-index: 10;
			animation: spinRotate 1s linear infinite;
			animation-play-state: paused;
		}
		.chat-spinner.is-active { opacity: 1; animation-play-state: running; }
		@keyframes spinRotate { to { transform: rotate(360deg); } }
		.chat-spinner-dot {
			position: absolute;
			width: clamp(0.25rem, 0.2rem + 0.1vw, 0.3125rem);
			height: clamp(0.25rem, 0.2rem + 0.1vw, 0.3125rem);
			border-radius: 50%;
			background: currentColor;
			left: 50%;
			top: 0;
			margin-left: -0.15625rem;
			transform-origin: 50% clamp(1rem, 0.875rem + 0.25vw, 1.125rem);
			opacity: 0.25;
		}
		.chat-spinner-dot:nth-child(1) { transform: rotate(0deg); opacity: 1; }
		.chat-spinner-dot:nth-child(2) { transform: rotate(45deg); opacity: 0.875; }
		.chat-spinner-dot:nth-child(3) { transform: rotate(90deg); opacity: 0.75; }
		.chat-spinner-dot:nth-child(4) { transform: rotate(135deg); opacity: 0.625; }
		.chat-spinner-dot:nth-child(5) { transform: rotate(180deg); opacity: 0.5; }
		.chat-spinner-dot:nth-child(6) { transform: rotate(225deg); opacity: 0.375; }
		.chat-spinner-dot:nth-child(7) { transform: rotate(270deg); opacity: 0.3; }
		.chat-spinner-dot:nth-child(8) { transform: rotate(315deg); opacity: 0.25; }
	</style>

<script src="../scripts/main.ts"></script>

</BaseLayout>
