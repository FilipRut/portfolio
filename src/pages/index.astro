			const FRAME_IDLE_ARM_UP: (string | null)[][] = [
				[T,  T,  O,  O,  O,  O,  O,  O,  O,  O,  T,  T],
				[T,  T,  O,  E,  O,  O,  O,  O,  E,  O,  T,  T],
