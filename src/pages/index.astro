---
import '../styles/global.css';
---

<html lang="pl">
	<head>
		<meta charset="utf-8" />
		<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
		<link rel="icon" href="/favicon.ico" />
		<meta name="viewport" content="width=device-width" />
		<meta name="generator" content={Astro.generator} />
		<title>Filip Rut – Lead UX/UI Designer</title>
		<link rel="preconnect" href="https://fonts.googleapis.com" />
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
		<link href="https://fonts.googleapis.com/css2?family=Inter+Tight:ital,wght@0,400;0,500;0,600;1,400&display=swap" rel="stylesheet" />
	</head>
	<body class="m-0 p-0 font-['Inter_Tight',sans-serif] bg-black">

		<!-- ═══ SCROLL WRAPPER: Hero stays frozen while prompter animates ═══ -->
		<div id="scroll-wrapper" class="scroll-wrapper">
			<section id="hero" class="hero-sticky" style="background-color: #E53E3E;">
				<!-- Gradient overlay -->
				<div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 50% 0%, rgba(220,50,50,0.4) 0%, transparent 60%), radial-gradient(ellipse at 80% 100%, rgba(100,0,0,0.3) 0%, transparent 50%);"></div>

				<!-- Frosted ribbed glass effect -->
				<div id="hero-glass" class="hero-glass">
					<div class="hero-glass-gradient"></div>
					<div class="hero-glass-frost"></div>
				</div>

				<!-- 5 vertical lines -->
				<div class="absolute inset-0 px-6 md:px-16 flex justify-between pointer-events-none">
					<div class="hero-line w-[2px] h-full" style="background-color: rgba(23,23,23,0.25);"></div>
					<div class="hero-line w-[2px] h-full hidden md:block" style="background-color: rgba(23,23,23,0.25);"></div>
					<div class="hero-line w-[2px] h-full hidden sm:block" style="background-color: rgba(23,23,23,0.25);"></div>
					<div class="hero-line w-[2px] h-full hidden md:block" style="background-color: rgba(23,23,23,0.25);"></div>
					<div class="hero-line w-[2px] h-full" style="background-color: rgba(23,23,23,0.25);"></div>
				</div>

				<!-- Top bar -->
				<div class="relative z-10 w-full px-6 md:px-16 pt-6 md:pt-8 pb-4 flex flex-wrap gap-2 md:gap-0 justify-between items-center self-start">
					<span class="hero-label text-stone-950 font-semibold tracking-tight" style="font-size: clamp(0.75rem, 0.6rem + 0.4vw, 0.9rem);">Filip Rut</span>
					<span class="hero-label text-stone-950 font-semibold tracking-tight" style="font-size: clamp(0.75rem, 0.6rem + 0.4vw, 0.9rem);">Lead UX/UI Designer</span>
					<span class="hero-label text-stone-950 font-semibold tracking-tight" style="font-size: clamp(0.75rem, 0.6rem + 0.4vw, 0.9rem);">10 yrs exp</span>
				</div>

				<!-- Big RUT text -->
				<div class="absolute bottom-0 left-0 right-0 flex justify-center pointer-events-none select-none overflow-hidden">
					<span class="hero-letter font-medium" style="color: #171717;">R</span>
					<span class="hero-letter font-medium" style="color: #171717;">U</span>
					<span class="hero-letter font-medium" style="color: #171717;">T</span>
				</div>
			</section>
		</div>

		<!-- ═══ AI PROMPTER (fixed overlay, persists across entire page) ═══ -->
		<div id="prompter-fixed" class="prompter-fixed">
			<!-- SVG frosted glass filter -->
			<svg style="position:absolute;width:0;height:0;">
				<defs>
					<filter id="frosted" x="-20%" y="-20%" width="140%" height="140%">
						<feTurbulence type="fractalNoise" baseFrequency="0.012" numOctaves="4" seed="2" result="noise"/>
						<feDisplacementMap in="SourceGraphic" in2="noise" scale="6" xChannelSelector="R" yChannelSelector="G"/>
					</filter>
				</defs>
			</svg>

			<div class="prompter-column">
				<div class="prompter-row">
					<!-- Dropdown toggle (hidden initially, appears on collapse) -->
					<button id="dropdown-btn" class="prompter-dropdown" aria-label="Show suggestions">
						<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:block;">
							<path d="M6 9l6 6 6-6"></path>
						</svg>
					</button>

					<div class="glass-container">
						<!-- Inner glass layer (inset/concave) -->
						<div class="prompter-textarea-wrap">
							<textarea id="ai-prompt" class="prompter-textarea" placeholder="Ask AI about me..."></textarea>

							<!-- Response overlay (top) -->
							<div class="glass-overlay-top">
								<div id="ai-response-title" class="text-white font-medium leading-none" style="font-size: clamp(2rem, 1.5rem + 2vw, 4rem);"></div>
								<p id="ai-response-text" class="font-normal leading-relaxed" style="font-size: clamp(0.9375rem, 0.85rem + 0.3vw, 1.1rem); margin-top: clamp(0.4rem, 0.3rem + 0.2vw, 0.6rem); color: rgba(255,255,255,0.7);"></p>
							</div>

							<!-- Send button -->
							<div class="glass-overlay-bottom">
								<div class="flex-1"></div>
								<button id="generate-btn" class="prompter-send" aria-label="Send">
									<svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:block;">
										<path d="M22 2L11 13"></path>
										<path d="M22 2L15 22L11 13L2 9L22 2Z"></path>
									</svg>
								</button>
							</div>
						</div>
					</div>
				</div>

				<!-- Suggestion bubbles (outside glass container) -->
				<div class="prompt-bubbles">
					<button class="prompt-bubble" data-prompt="What projects have you worked on?">What projects have you worked on?</button>
					<button class="prompt-bubble" data-prompt="What does your design process look like?">What does your design process look like?</button>
					<button class="prompt-bubble" data-prompt="What tools do you use?">What tools do you use?</button>
				</div>
			</div>
		</div>

		<!-- ═══ INTRO ═══ -->
		<section id="intro" class="w-full bg-white" style="min-height: 100vh; padding: clamp(1rem, 0.5rem + 1.5vw, 1.5rem) clamp(1.5rem, 1rem + 3vw, 4rem) clamp(2rem, 1.5rem + 2vw, 4rem);">
			<div class="flex flex-col lg:flex-row items-start lg:items-center" style="padding: clamp(1rem, 0.5rem + 1vw, 1.5rem) 0; gap: clamp(1.5rem, 1rem + 2vw, 3rem);">
				<!-- Photo + Heading group -->
				<div class="flex items-center shrink-0" style="gap: clamp(0.75rem, 0.5rem + 1vw, 1.5rem);">
					<img
						src="https://placehold.co/111x160/e5e5e5/737373?text=Photo"
						alt="Filip Rut"
						class="intro-el object-cover rounded"
						style="width: clamp(4rem, 3rem + 3vw, 7rem); height: clamp(5.5rem, 4rem + 4vw, 10rem);"
					/>
					<h2 class="intro-el text-stone-950 font-normal leading-tight" style="font-size: clamp(1.5rem, 1rem + 2.5vw, 3.5rem); max-width: 32rem;">
						Leading above the corporate chaos
					</h2>
				</div>

				<!-- Image + Description group -->
				<div class="flex-1 flex items-center" style="gap: clamp(0.75rem, 0.5rem + 1vw, 1.5rem); padding-left: clamp(0rem, 2vw, 5rem);">
					<img
						src="https://placehold.co/247x159/e5e5e5/737373?text=Keychains"
						alt="Design artifacts"
						class="intro-el object-cover shrink-0"
						style="width: clamp(6rem, 4rem + 6vw, 15rem); height: clamp(4rem, 3rem + 4vw, 10rem);"
					/>
					<p class="intro-el text-orange-950 font-normal leading-snug" style="font-size: clamp(0.875rem, 0.7rem + 0.8vw, 1.35rem);">
						An experienced Lead UX/UI designer and Webflow developer, delivering high-quality designs and websites.
					</p>
				</div>
			</div>
		</section>

		<style>
			/* Scroll wrapper — tall container, hero stays sticky inside */
			.scroll-wrapper {
				position: relative;
				height: 300vh; /* 100vh hero + 200vh scroll distance for prompter phases */
			}

			/* Hero sticky inside wrapper */
			.hero-sticky {
				position: sticky;
				top: 0;
				height: 100vh;
				z-index: 1;
				display: flex;
				flex-direction: column;
				overflow: hidden;
			}

			/* Frosted ribbed glass effect */
			.hero-glass {
				position: absolute;
				inset: 0;
				overflow: hidden;
				pointer-events: none;
				z-index: 0;
				mask-image: linear-gradient(
					to right,
					rgba(0,0,0,0) 3%,
					rgba(0,0,0,1) 15%,
					rgba(0,0,0,1) 85%,
					rgba(0,0,0,0) 97%
				);
			}

			.hero-glass-gradient {
				position: absolute;
				inset: -20%;
				background: radial-gradient(
					ellipse at 50% 50%,
					rgba(210, 50, 50, 0.15) 0%,
					transparent 70%
				);
				mix-blend-mode: hard-light;
			}

			.hero-glass-frost {
				position: absolute;
				inset: 0;
				width: 200%;
				transform: scale(2);
				background-image: repeating-linear-gradient(
					to right,
					rgba(255, 255, 255, 0.04) 0%,
					rgba(0, 0, 0, 0.39) 49%,
					rgba(255, 255, 255, 0.27) 100%
				);
				background-size: 40px;
				mix-blend-mode: color-dodge;
				backdrop-filter: blur(20px);
				-webkit-backdrop-filter: blur(20px);
				animation: frost-drift 90s linear infinite;
			}

			@keyframes frost-drift {
				from { transform: scale(2) translateX(0); }
				to { transform: scale(2) translateX(-50%); }
			}

			/* Fixed prompter overlay */
			.prompter-fixed {
				position: fixed;
				top: 0;
				left: 0;
				right: 0;
				z-index: 100;
				display: flex;
				justify-content: center;
				padding: 0 clamp(1.5rem, 1rem + 2vw, 3rem);
				pointer-events: none;
			}

			.prompter-fixed > .prompter-column {
				pointer-events: auto;
			}

			.hero-text {
				font-family: 'Inter Tight', sans-serif;
				font-size: clamp(200px, 38vw, 650px);
				line-height: 0.82;
				letter-spacing: 0.02em;
				margin-bottom: -0.04em;
			}

			.hero-letter {
				font-family: 'Inter Tight', sans-serif;
				font-size: clamp(200px, 38vw, 650px);
				line-height: 0.82;
				letter-spacing: 0.02em;
				margin-bottom: -0.04em;
				display: inline-block;
			}

			.prompter-column {
				position: relative;
				display: flex;
				flex-direction: column;
				align-items: stretch;
				width: 100%;
				max-width: 50%;
				gap: clamp(0.75rem, 0.5rem + 0.5vw, 1.25rem);
			}

			.prompter-row {
				display: flex;
				align-items: center;
				width: 100%;
				gap: clamp(0.5rem, 0.3rem + 0.3vw, 0.75rem);
			}

			.prompter-dropdown {
				position: absolute;
				left: -56px;
				top: 0;
				width: 48px;
				height: 48px;
				min-width: 48px;
				border-radius: 50%;
				border: 0.75px solid transparent;
				background: rgba(255, 255, 255, 0.08);
				color: #fff;
				cursor: pointer;
				display: grid;
				place-items: center;
				padding: 0;
				line-height: 0;
				transition: none;
				box-shadow:
					0 0 0 0.75px rgba(255, 255, 255, 0.08),
					0 8px 20px rgba(0, 0, 0, 0.12);
				backdrop-filter: url(#frosted) blur(12px) saturate(120%);
				-webkit-backdrop-filter: url(#frosted) blur(12px) saturate(120%);
				opacity: 0;
				pointer-events: none;
			}

			.prompter-dropdown.is-visible {
				opacity: 1;
				pointer-events: auto;
				transform: translateX(0);
			}

			.prompter-dropdown:hover {
				background: rgba(255, 255, 255, 0.14);
				box-shadow:
					0 0 0 0.75px rgba(255, 255, 255, 0.15),
					0 10px 24px rgba(0, 0, 0, 0.18);
			}

			.prompter-dropdown.is-open svg {
				transform: rotate(180deg);
			}

			.prompter-dropdown svg {
				transition: transform 0.3s ease;
			}

			@media (max-width: 1024px) {
				.prompter-column { max-width: 80%; }
			}

			@media (max-width: 640px) {
				.prompter-column { max-width: 95%; }
			}

			/* Glass container — outer layer, semi-dark for readability */
			.glass-container {
				position: relative;
				width: 100%;
				min-height: clamp(16rem, 12rem + 8vw, 24rem);
				border-radius: clamp(0.75rem, 0.5rem + 0.5vw, 1.25rem);
				background: rgba(255, 255, 255, 0.04);
				backdrop-filter: blur(40px) saturate(150%);
				-webkit-backdrop-filter: blur(40px) saturate(150%);
				border: 1px solid rgba(255, 255, 255, 0.1);
				box-shadow:
					0 8px 32px rgba(0, 0, 0, 0.25),
					inset 0 1px 0 rgba(255, 255, 255, 0.08);
				overflow: hidden;
				padding: clamp(0.4rem, 0.3rem + 0.2vw, 0.6rem);
			}

			/* Textarea wrapper — inner glass layer, denser, inset look */
			.prompter-textarea-wrap {
				position: relative;
				flex: 1;
				min-height: clamp(14rem, 10rem + 7vw, 22rem);
				border-radius: clamp(0.5rem, 0.35rem + 0.3vw, 0.85rem);
				background: rgba(255, 255, 255, 0.04);
				backdrop-filter: blur(20px) saturate(130%);
				-webkit-backdrop-filter: blur(20px) saturate(130%);
				border: 0.75px solid rgba(255, 255, 255, 0.08);
				box-shadow:
					inset 0 2px 8px rgba(0, 0, 0, 0.35),
					inset 0 1px 2px rgba(0, 0, 0, 0.25),
					inset 0 -1px 0 rgba(255, 255, 255, 0.04);
				overflow: hidden;
			}

			/* Textarea — fills inner glass, fully transparent */
			.prompter-textarea {
				position: absolute;
				inset: 0;
				width: 100%;
				height: 100%;
				font-family: 'Inter Tight', sans-serif;
				font-size: clamp(0.9375rem, 0.85rem + 0.25vw, 1.1rem);
				padding: clamp(1rem, 0.75rem + 0.5vw, 1.5rem);
				padding-bottom: clamp(3.5rem, 3rem + 1vw, 5rem);
				background: transparent;
				border: none;
				color: rgba(255, 255, 255, 0.9);
				outline: none;
				resize: none;
				overflow: hidden;
				line-height: 1.6;
				caret-color: #E53E3E;
				scrollbar-width: none;
			}

			.prompter-textarea::-webkit-scrollbar {
				display: none;
			}

			.prompter-textarea::placeholder {
				color: rgba(255, 255, 255, 0.5);
			}

			/* ── Light mode overrides (when over white/light bg) ── */
			.prompter-fixed.on-light .prompter-textarea {
				color: rgba(0, 0, 0, 0.85);
				caret-color: #E53E3E;
			}
			.prompter-fixed.on-light .prompter-textarea::placeholder {
				color: rgba(0, 0, 0, 0.4);
			}
			.prompter-fixed.on-light .glass-container {
				border-color: rgba(0, 0, 0, 0.08);
				box-shadow:
					0 8px 32px rgba(0, 0, 0, 0.1),
					inset 0 1px 0 rgba(255, 255, 255, 0.5);
			}
			.prompter-fixed.on-light .prompter-textarea-wrap {
				border-color: rgba(0, 0, 0, 0.06);
				box-shadow:
					inset 0 2px 8px rgba(0, 0, 0, 0.08),
					inset 0 1px 2px rgba(0, 0, 0, 0.06);
			}
			.prompter-fixed.on-light #ai-response-title {
				color: rgba(0, 0, 0, 0.9);
			}
			.prompter-fixed.on-light #ai-response-text {
				color: rgba(0, 0, 0, 0.55);
			}
			.prompter-fixed.on-light .prompt-bubble {
				background: rgba(0, 0, 0, 0.06);
				color: rgba(0, 0, 0, 0.8);
				box-shadow:
					0 0 0 0.75px rgba(0, 0, 0, 0.06),
					0 4px 12px rgba(0, 0, 0, 0.06);
			}
			.prompter-fixed.on-light .prompt-bubble:hover {
				background: rgba(0, 0, 0, 0.1);
				color: rgba(0, 0, 0, 0.9);
				box-shadow:
					0 0 0 0.75px rgba(0, 0, 0, 0.1),
					0 6px 16px rgba(0, 0, 0, 0.1);
			}
			.prompter-fixed.on-light .prompter-dropdown {
				background: rgba(0, 0, 0, 0.06);
				color: rgba(0, 0, 0, 0.7);
				box-shadow:
					0 0 0 0.75px rgba(0, 0, 0, 0.06),
					0 4px 12px rgba(0, 0, 0, 0.06);
			}
			.prompter-fixed.on-light .prompter-dropdown:hover {
				background: rgba(0, 0, 0, 0.1);
			}

			/* Smooth color transitions */
			.prompter-textarea,
			.glass-container,
			.prompter-textarea-wrap,
			.prompt-bubble,
			.prompter-dropdown,
			#ai-response-title,
			#ai-response-text {
				transition: color 0.4s ease, background 0.4s ease, border-color 0.4s ease, box-shadow 0.4s ease;
			}

			/* Response overlay — top area */
			.glass-overlay-top {
				position: absolute;
				top: 0;
				left: 0;
				right: 0;
				padding: clamp(1.25rem, 1rem + 0.5vw, 2rem);
				pointer-events: none;
				z-index: 2;
			}

			/* Bottom bar — tags + send, fades from glass */
			.glass-overlay-bottom {
				position: absolute;
				bottom: 0;
				left: 0;
				right: 0;
				display: flex;
				align-items: flex-end;
				gap: clamp(0.5rem, 0.3rem + 0.3vw, 0.75rem);
				padding: clamp(0.75rem, 0.5rem + 0.4vw, 1.25rem);
				background: none;
				z-index: 2;
			}

			.prompter-send {
				width: 48px;
				height: 48px;
				border-radius: 50%;
				border: 0.75px solid transparent;
				background: rgba(229, 62, 62, 0.85);
				color: #fff;
				cursor: pointer;
				display: grid;
				place-items: center;
				flex-shrink: 0;
				padding: 2px 2px 0 0;
				line-height: 0;
				transition: all 0.25s ease;
				box-shadow:
					0 0 0 0.75px rgba(255, 255, 255, 0.08),
					0 8px 20px rgba(0, 0, 0, 0.12);
				backdrop-filter: url(#frosted) blur(12px) saturate(120%);
				-webkit-backdrop-filter: url(#frosted) blur(12px) saturate(120%);
			}

			.prompter-send:hover:not(:disabled) {
				background: rgba(229, 62, 62, 1);
				transform: translateY(-1px) scale(1.08);
				box-shadow:
					0 0 0 0.75px rgba(255, 255, 255, 0.15),
					0 10px 24px rgba(0, 0, 0, 0.18);
			}

			.prompter-send:disabled {
				opacity: 0.4;
				cursor: not-allowed;
				transform: none;
			}

			/* Suggestion bubbles (below glass container) */
			.prompt-bubbles {
				display: flex;
				flex-wrap: wrap;
				justify-content: center;
				width: 100%;
				gap: clamp(0.4rem, 0.3rem + 0.25vw, 0.6rem);
			}

			.prompt-bubble {
				font-family: 'Inter Tight', sans-serif;
				font-size: clamp(0.75rem, 0.65rem + 0.2vw, 0.9rem);
				padding: clamp(0.3rem, 0.25rem + 0.15vw, 0.45rem) clamp(0.7rem, 0.5rem + 0.35vw, 1rem);
				border-radius: 999px;
				border: 0.75px solid transparent;
				background: rgba(255, 255, 255, 0.08);
				color: rgba(255, 255, 255, 1);
				cursor: pointer;
				transition: all 0.25s ease;
				box-shadow:
					0 0 0 0.75px rgba(255, 255, 255, 0.08),
					0 8px 20px rgba(0, 0, 0, 0.12);
				backdrop-filter: url(#frosted) blur(12px) saturate(120%);
				-webkit-backdrop-filter: url(#frosted) blur(12px) saturate(120%);
			}

			.prompt-bubble:hover {
				background: rgba(255, 255, 255, 0.14);
				color: rgba(255, 255, 255, 1);
				box-shadow:
					0 0 0 0.75px rgba(255, 255, 255, 0.15),
					0 10px 24px rgba(0, 0, 0, 0.18);
				transform: translateY(-1px);
			}

		</style>

		<script>
			import gsap from 'gsap';
			import { ScrollTrigger } from 'gsap/ScrollTrigger';
			gsap.registerPlugin(ScrollTrigger);

			/* ── HERO ENTRANCE ── */
			const heroTl = gsap.timeline({ defaults: { ease: 'power3.out' } });

			heroTl.from('.hero-label', {
				y: -20, opacity: 0, duration: 0.8, stagger: 0.15,
			});

			heroTl.from('.hero-line', {
				scaleY: 0, transformOrigin: 'top center',
				duration: 1, stagger: 0.08, ease: 'power2.inOut',
			}, '-=0.6');

			heroTl.fromTo('.hero-letter',
				{ y: '120%', opacity: 0 },
				{ y: '0%', opacity: 1, duration: 1.4, stagger: 0.12, ease: 'power4.out' },
			'-=0.8');

			/* ── FIXED PROMPTER ── */
			const prompterFixed = document.querySelector<HTMLElement>('#prompter-fixed')!;
			const glassContainer = document.querySelector<HTMLElement>('.glass-container')!;
			const textareaWrap = document.querySelector<HTMLElement>('.prompter-textarea-wrap')!;
			const overlayTop = document.querySelector<HTMLElement>('.glass-overlay-top')!;
			const overlayBottom = document.querySelector<HTMLElement>('.glass-overlay-bottom')!;
			const bubblesWrap = document.querySelector<HTMLElement>('.prompt-bubbles')!;
			const dropdownBtn = document.querySelector<HTMLButtonElement>('#dropdown-btn')!;
			const prompterColumn = document.querySelector<HTMLElement>('.prompter-column')!;

			const vh = window.innerHeight;
			const colH = prompterColumn.offsetHeight;

			// Positions (y values for the column inside flex-start container)
			const yOffScreen = vh + 100;                  // below viewport
			const yCentered = (vh - colH) / 2;            // vertically centered
			const yTop = 16;                               // 1rem from top

			// Start off-screen
			gsap.set(prompterColumn, { y: yOffScreen });
			gsap.set('.prompt-bubble', { y: 20, opacity: 0, scale: 0.9 });

			/*
			 * scroll-wrapper is 300vh:
			 *   scroll 0–100vh: hero visible, nothing happens
			 *   100vh–200vh (Phase 1): prompter slides from bottom to center
			 *   200vh–300vh (Phase 2): collapse to pill + move to top 1rem
			 */

			// Phase 1: Slide up from below to center
			const slideTl = gsap.timeline({
				scrollTrigger: {
					trigger: '#scroll-wrapper',
					start: `${vh}px top`,
					end: `${vh * 2}px top`,
					scrub: true,
				},
			});

			slideTl
				.to(prompterColumn, {
					y: yCentered,
					duration: 1,
					ease: 'power2.out',
				})
				.to('.prompt-bubble', {
					y: 0, opacity: 1, scale: 1,
					stagger: 0.05,
					duration: 0.4,
					ease: 'back.out(1.7)',
				}, 0.5);

			// Phase 2: Collapse to pill + move to top
			const collapseTl = gsap.timeline({
				defaults: { duration: 1, ease: 'none' },
				scrollTrigger: {
					trigger: '#scroll-wrapper',
					start: `${vh * 2}px top`,
					end: `${vh * 3}px top`,
					scrub: true,
				},
			});

			collapseTl
				// Move column from center to 1rem from top
				.to(prompterColumn, {
					y: yTop,
					duration: 1,
				}, 0)

				// Glass container → pill
				.to(glassContainer, { keyframes: [
					{ minHeight: '120px', padding: '3px', borderRadius: '16px', duration: 0.6 },
					{ minHeight: '40px', padding: '2px', borderRadius: '30px', duration: 0.4 },
				] }, 0)

				// Textarea wrap → pill
				.to(textareaWrap, { keyframes: [
					{ minHeight: '100px', borderRadius: '12px', duration: 0.6 },
					{ minHeight: '36px', borderRadius: '30px', duration: 0.4 },
				] }, 0)

				// Textarea → single line
				.to('.prompter-textarea', {
					paddingTop: '0px', paddingBottom: '0px',
					height: '36px', lineHeight: '36px',
					duration: 1,
				}, 0)

				// Send button shrink
				.to('#generate-btn', { width: '30px', height: '30px', duration: 1 }, 0)
				.to('#generate-btn svg', { width: '14px', height: '14px', duration: 1 }, 0)

				// Overlay top fade
				.to(overlayTop, { opacity: 0, duration: 0.3 }, 0)

				// Overlay bottom → collapsed
				.to(overlayBottom, {
					height: '36px',
					padding: '3px',
					duration: 1,
				}, 0)

				// Bubbles hide
				.to(bubblesWrap, { y: -20, opacity: 0, pointerEvents: 'none', duration: 0.4 }, 0)

				// Dropdown shrink + appear
				.to(dropdownBtn, { width: '36px', height: '36px', minWidth: '36px', duration: 1 }, 0)
				.to('#dropdown-btn svg', { width: '14px', height: '14px', duration: 1 }, 0)
				.to(dropdownBtn, {
					opacity: 1, pointerEvents: 'auto', duration: 0.4,
					onComplete: () => dropdownBtn.classList.add('is-visible'),
					onReverseComplete: () => {
						dropdownBtn.classList.remove('is-visible', 'is-open');
						bubblesOpen = false;
					},
				}, 0.5);

			/* ── INTRO SECTION ── */
			gsap.fromTo('.intro-el',
				{ y: 40, opacity: 0 },
				{
					y: 0, opacity: 1, duration: 0.8, stagger: 0.15, ease: 'power3.out',
					scrollTrigger: { trigger: '#intro', start: 'top 80%', once: true },
				}
			);

			/* ── DROPDOWN TOGGLE ── */
			let bubblesOpen = false;

			dropdownBtn.addEventListener('click', () => {
				bubblesOpen = !bubblesOpen;
				dropdownBtn.classList.toggle('is-open', bubblesOpen);

				if (bubblesOpen) {
					gsap.to(bubblesWrap, {
						y: 0, opacity: 1, pointerEvents: 'auto',
						duration: 0.4, ease: 'back.out(1.7)',
					});
				} else {
					gsap.to(bubblesWrap, {
						y: -20, opacity: 0, pointerEvents: 'none',
						duration: 0.3, ease: 'power2.in',
					});
				}
			});

			/* ── AI PROMPTER LOGIC ── */
			const KNOWLEDGE_BASE: Record<string, { title: string; text: string }> = {
				'What projects have you worked on?': {
					title: '10 years',
					text: 'I\'ve designed e-commerce systems, SaaS applications, and corporate websites. I\'ve worked across retail, fintech, and education — from research to implementation.',
				},
				'What does your design process look like?': {
					title: 'Process',
					text: 'Research → wireframing → prototype → user testing → pixel-perfect UI in Figma. Every stage is data-driven, never guesswork.',
				},
				'What tools do you use?': {
					title: 'Stack',
					text: 'Figma, FigJam, Webflow, AI tools for automating repetitive tasks. Design system as the foundation of every project.',
				},
			};

			const FALLBACK = {
				title: '404',
				text: 'My language model hasn\'t processed that yet, but I\'d love to tell you more about it in person!',
			};

			const wait = (ms: number) => new Promise((r) => setTimeout(r, ms));

			const typeWriterEffect = async (el: HTMLElement, text: string, speed: number) => {
				el.innerHTML = '';
				for (const char of text) {
					el.innerHTML += char;
					await wait(speed);
				}
			};

			const promptInput = document.querySelector<HTMLTextAreaElement>('#ai-prompt')!;
			const generateBtn = document.querySelector<HTMLButtonElement>('#generate-btn')!;
			const responseTitle = document.querySelector<HTMLElement>('#ai-response-title')!;
			const responseText = document.querySelector<HTMLElement>('#ai-response-text')!;
			const triggers = document.querySelectorAll<HTMLButtonElement>('.prompt-bubble');

			triggers.forEach((tag) => {
				tag.addEventListener('click', () => {
					promptInput.value = tag.dataset.prompt ?? '';
					generateBtn.style.transform = 'scale(1.05)';
					setTimeout(() => { generateBtn.style.transform = 'scale(1)'; }, 200);
				});
			});

			generateBtn.addEventListener('click', async () => {
				const query = promptInput.value.trim();
				if (!query) return;

				generateBtn.disabled = true;
				generateBtn.style.opacity = '0.5';

				responseTitle.innerHTML = '';
				responseText.innerHTML = '';

				await wait(500);

				const match = KNOWLEDGE_BASE[query] ?? FALLBACK;

				await typeWriterEffect(responseTitle, match.title, 40);
				await typeWriterEffect(responseText, match.text, 15);

				generateBtn.disabled = false;
				generateBtn.style.opacity = '1';
			});

			/* ── AUTO DETECT BACKGROUND → SWITCH COLORS ── */
			const lightSections = document.querySelectorAll<HTMLElement>('#intro');

			const checkBackground = () => {
				const col = prompterColumn.getBoundingClientRect();
				const colMid = col.top + col.height / 2;
				let isLight = false;

				lightSections.forEach((sec) => {
					const rect = sec.getBoundingClientRect();
					if (colMid >= rect.top && colMid <= rect.bottom) {
						isLight = true;
					}
				});

				prompterFixed.classList.toggle('on-light', isLight);
			};

			ScrollTrigger.addEventListener('refresh', checkBackground);
			window.addEventListener('scroll', checkBackground, { passive: true });
			checkBackground();
		</script>

	</body>
</html>
